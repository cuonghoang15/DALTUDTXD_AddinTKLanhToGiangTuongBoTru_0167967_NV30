<Window x:Class="DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30.Views.DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30.Views"
        mc:Ignorable="d"
        Title="DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30View" Height="700" Width="1000">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
            Background="#1565C0" Grid.ColumnSpan="2">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🏗 THIẾT KẾ LANH TÔ &amp; GIẰNG TƯỜNG &amp; BỔ TRỤ"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                    Width="35"
                    Height="35"
                    Content="✕"
                    />
            </Grid>

        </Border>

        <!-- Nội dung -->
        <TabControl Grid.Row="1"
                Margin="15,15,15,15" Grid.ColumnSpan="2">
            <!-- TAB GIẰNG TƯỜNG -->
            <TabItem Header="Giằng tường">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cột trái -->
                    <StackPanel Grid.Column="0">

                        <GroupBox Header="Thông số đầu vào">

                            <StackPanel Margin="10">

                                <TextBlock Text="Khoảng cách giằng (m)"/>
                                <TextBox Height="30"
                             Text="{Binding KhoangCachGiang}"/>

                                <TextBlock Margin="0,10,0,0"
                               Text="Chiều cao giằng (mm)"/>
                                <TextBox Height="30"
                             Text="{Binding ChieuCaoGiang}"/>

                                <TextBlock Margin="0,10,0,0"
                               Text="Chiều rộng giằng (mm)"/>
                                <TextBox Height="30"
                             Text="{Binding ChieuRongGiang}"/>

                            </StackPanel>

                        </GroupBox>
                        <GroupBox Header="Quy tắc bố trí"
                                  Margin="0,15,0,0">

                            <StackPanel Margin="10">

                                <RadioButton Content="Giằng mỗi 4m chiều cao"/>

                                <RadioButton Content="Giằng đỉnh tường"/>

                                <RadioButton Content="Khoảng cách tùy chỉnh"/>

                            </StackPanel>

                        </GroupBox>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,15,0,0">

                            <Button Width="150"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Content="Lấy dữ liệu Revit"/>

                            <Button Width="150"
                                    Height="40"
                                    Content="Tính toán"/>

                        </StackPanel>

                        <GroupBox Header="Danh sách tường"
                                  Margin="0,20,0,0">

                            <DataGrid Height="150"
                                      AutoGenerateColumns="False" Margin="10,0,0,0" HorizontalAlignment="Left" Width="607">

                                <DataGrid.Columns>

                                    <DataGridTextColumn Header="Tên tường"
                                                         Width="*"/>

                                    <DataGridTextColumn Header="Dài (m)"
                                                        Width="100"/>

                                    <DataGridTextColumn Header="Cao (m)"
                                                        Width="100"/>

                                    <DataGridTextColumn Header="Số giằng"
                                                        Width="100"/>

                                </DataGrid.Columns>

                            </DataGrid>

                        </GroupBox>

                    </StackPanel>
                    <!-- Cột phải -->
                    <StackPanel Grid.ColumnSpan="2" Height="546" Margin="629,0,0,0" VerticalAlignment="Top">

                        <Border Background="White"
                                CornerRadius="8"
                                Padding="20"
                                Margin="10"
                                BorderBrush="#DADADA"
                                BorderThickness="1">

                            <StackPanel>

                                <TextBlock Text="TỔNG SỐ GIẰNG"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding TongSoGiang}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#1565C0"/>

                            </StackPanel>

                        </Border>

                        <Border Background="White"
                                CornerRadius="8"
                                Padding="20"
                                Margin="10"
                                BorderBrush="#DADADA"
                                BorderThickness="1">

                            <StackPanel>

                                <TextBlock Text="TỔNG CHIỀU DÀI"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding TongChieuDaiGiang}"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </Grid>

            </TabItem>
        </TabControl>
    </Grid>
</Window>
