<Window x:Class="DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30.Views.DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:local="clr-namespace:DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30.Views"
 mc:Ignorable="d"
 Title="DALTUDTXD_AddinTKLanhToGiangTuongBoTru_0167967_NV30View" Height="700" Width="1000">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
         Background="#1565C0">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🏗 THIẾT KẾ LANH TÔ &amp; GIẰNG TƯỜNG &amp; BỔ TRỤ"
                    Foreground="White"
                    FontSize="22"
                    FontWeight="Bold"
                    VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                 Width="35"
                 Height="35"
                 Content="✕"
                 Click="CloseButton_Click"/>
            </Grid>

        </Border>
        <!-- Nội dung -->
        <TabControl Grid.Row="1"
             Margin="15">

            <!-- TAB LANH TÔ -->
            <TabItem Header="Lanh tô">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cột trái -->
                    <StackPanel Grid.Column="0">

                        <GroupBox Header="Thông số đầu vào"
                           Margin="0,0,10,10">

                            <StackPanel Margin="10">

                                <TextBlock Text="Chiều dài gối lanh tô"/>
                                <TextBox Height="30"/>

                                <TextBlock Margin="0,10,0,0"
                                    Text="Chiều cao lanh tô"/>
                                <TextBox Height="30"/>

                                <TextBlock Margin="0,10,0,0"
                                    Text="Chiều rộng tiết diện"/>
                                <TextBox Height="30"/>

                            </StackPanel>

                        </GroupBox>
                        <StackPanel Orientation="Horizontal">

                            <Button Width="150"
             Height="40"
             Margin="0,0,10,0"
             Content="Lấy dữ liệu Revit"/>

                            <Button Width="150"
             Height="40"
             Content="Tính toán"/>

                        </StackPanel>

                        <GroupBox Header="Danh sách cửa"
           Margin="0,20,0,0">

                            <DataGrid Height="250"
               AutoGenerateColumns="False">

                                <DataGrid.Columns>

                                    <DataGridTextColumn Header="Tên cửa"/>
                                    <DataGridTextColumn Header="Rộng (m)"/>
                                    <DataGridTextColumn Header="Lanh tô (m)"/>

                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>



    </Grid>


</Window>
